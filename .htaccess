RewriteEngine On

# 1. Empêcher la boucle infinie si l'URL est déjà réécrite
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# 2. Vérifier si le fichier .php existe en interne et réécrire l'URL proprement
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]